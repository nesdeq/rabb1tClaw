# rabb1tClaw - API Keys
# Copy this file to .env and fill in your keys.
# Run 'rabb1tclaw init' to auto-detect these and configure providers.

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# DeepInfra (https://deepinfra.com/dash/api_keys)
DEEPINFRA_API_KEY=

# Serper — web search for the search agent (https://serper.dev)
# Free tier: 2,500 searches, no payment info required.
SERP_API_KEY=
